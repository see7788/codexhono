{
  "name": "honoapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "honocodex": "./scrpits/bin.js",
    "honocodex-dev": "./scrpits/bin.js",
    "honocodex-stop": "./scrpits/bin.js",
    "honocodex-restart": "./scrpits/bin.js"
  },
  "scripts": {
    "build": "tsup scrpits/bin.ts --format esm --platform node --target node20 --splitting false --no-sourcemap --no-dts --out-dir scrpits",
    "build:vscode": "tsup scrpits/vscode.ts --format esm --platform node --target node20 --splitting false --no-sourcemap --no-dts --external vscode --out-dir scrpits",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "0.6.0",
    "@openai/codex-sdk": "^0.136.0",
    "create-vite-router": "workspace:*",
    "extendszustand-lib": "workspace:*",
    "hono": "^4.12.18",
    "imapflow": "^1.3.3",
    "immer": "10.2.0",
    "mailparser": "^3.9.8",
    "openai": "^6.37.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.40",
    "@types/vscode": "^1.120.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
